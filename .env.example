# Runtime
PORT=8000
KOS_ENV=development

# GitHub runtime connector
# Use um token restrito ao repositório necessário. Nunca faça commit do valor real.
KOS_GITHUB_TOKEN=
KOS_GITHUB_REPOSITORY=vkb-lab/OS-v1

# Local worker
KOS_LOCAL_WORKER_ENABLED=false
KOS_LOCAL_ALLOWED_ROOTS=C:\Users\oi\Desktop;C:\Users\oi\Documents

# Database (próxima fase)
DATABASE_URL=

# Google Workspace / OAuth (configuração externa necessária)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_WORKSPACE_DOMAIN=kaizen-org.com
GOOGLE_SYSTEM_EMAIL=
